{application, collaborative_editor, [
    {description, "A collaborative text editor back-end"},
    {vsn, "0.0.0"},
    % Entry point of the application
    {mod, {collaborative_editor_app, []}},
    % Which dependencies must be started before Erlang tries to run this application
    {applications, [
        kernel,
        stdlib,
        cowboy,
        jsx,
        mnesia
    ]},
]}.